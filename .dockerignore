# 2B Tex Docker/Railway build ignore

.git
.github
node_modules
**/node_modules

# Local logs and backups
logs
Reports
backup-before-*
backend/backups
*.log
*.err.log
*.bak
*.bak-*

# Local-only runtimes and sessions
cloudflared.exe
*.exe

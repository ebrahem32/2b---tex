# ============================================================
# 2B Tex - Git ignore rules
# ============================================================

# قاعدة البيانات
# نتجاهل كل محتويات backend/data عدا نسخة التشغيل الأساسية المرفوعة للـ Railway seed.
backend/data/**
!backend/data/2btex.sqlite
*.sqlite3
*.db

# النسخ الاحتياطية
backend/backups/
backup-before-*/
Codex/

# السجلات
logs/
*.log
*.err.log

# المتغيرات السرية ومفاتيح API
.env
ai-service/.env
!.env.example
!**/.env.example

# ملفات تنفيذية كبيرة ومحلية
cloudflared.exe
*.exe

# تبعيات Node.js
node_modules/
**/node_modules/

# Node portable الخاص بواتساب
whatsapp-service/runtime/

# بيانات جلسة واتساب
whatsapp-service/data/
.wwebjs_auth/
.wwebjs_cache/

# التقارير والملفات المولدة
Reports/

# ملفات Backup يدوية
*.bak
*.bak-*

# ملفات Windows
*.lnk
Thumbs.db
Desktop.ini

# ملفات مؤقتة
*.tmp
*.temp
